        "jsCode": "const parsed = JSON.parse($input.first().json.output);\n\nconsole.log(parsed);\n\nreturn [\n  {\n    json: {\n      reply: parsed.reply || \"\",\n      \n      contact_id: $('When Executed by Another Workflow').first().json.contact_id,\n\n      lead_score: Number(parsed.lead_score || 0),\n\n      lead_temperature: parsed.lead_temperature || \"Cold\",\n\n      reason: parsed.reason || \"\",\n\n      urgency: parsed.urgency || \"Not urgent\",\n\n      raw_output: $json.output\n    }\n  }\n];"
