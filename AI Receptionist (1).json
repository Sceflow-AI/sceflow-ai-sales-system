{
  "name": "AI Receptionist",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// ============================================\n// SCEFLOW AI — CHATBOT CODE NODE (v3)\n// Parses AI JSON response\n// ============================================\n\nconst input = $input.first().json;\n\n// ─── GET RAW AI OUTPUT ─────────────────────\nconst rawOutput = input.output  || \n                  input.text    || \n                  input.aiReply || '';\n\n// ─── PARSE JSON FROM AI ────────────────────\nlet parsed = {};\ntry {\n  // Remove markdown code blocks if present\n  const cleaned = rawOutput\n    .replace(/```json/gi, '')\n    .replace(/```/g, '')\n    .trim();\n  \n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  // AI didn't return JSON — use raw as reply\n  parsed = {\n    reply: rawOutput,\n    extractedName: null,\n    extractedEmail: null,\n    intent: 'none'\n  };\n}\n\n// ─── INPUT VARIABLES ───────────────────────\nconst knownName    = input.knownName    || '';\nconst knownEmail   = input.knownEmail   || '';\nconst messageCount = parseInt(input.messageCount) || 0;\nconst userMessage  = input.userMessage  || '';\nconst sessionId    = input.sessionId    || '';\n\n// ─── EXTRACTED VALUES FROM AI ──────────────\nconst aiReply      = parsed.reply         || rawOutput;\nconst detectedName = parsed.extractedName  || null;\nconst detectedEmail= parsed.extractedEmail || null;\nconst detectedIntent= parsed.intent || 'none';\n\n// ─── FINAL MERGED VALUES ───────────────────\n// Keep existing known values if AI found nothing new\nconst finalName  = detectedName  || knownName  || null;\nconst finalEmail = detectedEmail || knownEmail || null;\n\n// ─── NEW CAPTURE FLAGS ─────────────────────\nconst newNameCaptured = !!(\n  detectedName &&\n  detectedName.toLowerCase() !== knownName.toLowerCase()\n);\n\nconst newEmailCaptured = !!(\n  detectedEmail &&\n  detectedEmail.toLowerCase() !== knownEmail.toLowerCase()\n);\n\nconst shouldUpdateSheet = newNameCaptured || newEmailCaptured;\n\n// ─── STATUS ────────────────────────────────\nlet status = 'Browsing';\nif (finalEmail)            status = 'Lead Captured';\nelse if (finalName)        status = 'Name Captured';\nelse if (messageCount > 2) status = 'Engaged';\n\n// ─── OUTPUT ────────────────────────────────\nreturn [{\n  json: {\n    ...input,\n\n    // Clean AI reply for chat widget\n    aiReply,\n\n    // Name and email\n    extractedName:        finalName,\n    extractedEmail:       finalEmail,\n    detectedName:         detectedName,\n    detectedEmail:        detectedEmail,\n    intent:               detectedIntent,\n\n    // Flags for IF nodes\n    newNameCaptured,\n    newEmailCaptured,\n    shouldUpdateSheet,\n\n    // Updated values\n    updatedMessageCount:  $('Execute a SQL query1').first().json.message_count + 1,\n    knownName:            finalName  || knownName,\n    knownEmail:           finalEmail || knownEmail,\n    status,\n    sessionId,\n    userMessage\n  }\n}];"
      },
